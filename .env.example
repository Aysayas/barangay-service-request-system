# ------------------------------------------------------------------
# eBarangayHub local environment template
# ------------------------------------------------------------------
# Copy this file to ".env" in the project root.
#
# Important:
# - Keep .env out of Git.
# - Database credentials are currently configured in app/config/database.php.
# - If mail or AI is not configured, the app still works with safe fallbacks.

# ------------------------------------------------------------------
# Gmail SMTP (optional)
# ------------------------------------------------------------------
# Leave these blank if you do not want email notifications during local setup.
# The app will skip email sending safely when credentials are incomplete.

MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_google_app_password_without_spaces
MAIL_FROM_EMAIL=your_gmail_address@gmail.com
MAIL_FROM_NAME=eBarangayHub Notifications

# ------------------------------------------------------------------
# AI integration (optional)
# ------------------------------------------------------------------
# Keep AI_ENABLED=false for normal local demos if you do not have a provider key.
# The assistant and report summaries will fall back automatically.

AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT=30
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.2

# Feature toggles
AI_ASSISTANT_ENABLED=true
AI_REPORT_SUMMARIES_ENABLED=true

# Logging and output limits
AI_LOG_VERBOSE=false
AI_MAX_ASSISTANT_CHARS=1200
AI_MAX_REPORT_SUMMARY_CHARS=700

# ------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------
# Required app setup still includes:
# - app/config/database.php
# - database/full_database_rebuild.sql import
# - composer install
# - npm install
# - npm run build
